# FaultLab 配置文件
# 复制本文件为 .env，填入你的配置
# .env 已被 .gitignore 忽略，不会提交到仓库

# LLM verify 配置（默认接入 Qwen / DashScope 兼容 OpenAI API）
VERIFY_PROVIDER=qwen
VERIFY_MODEL=qwen-plus

# Qwen（阿里云 DashScope）Key，获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 可选：自定义 OpenAI 兼容接口地址（默认按 VERIFY_PROVIDER 内置）
# VERIFY_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 可选：切换到 OpenAI
# VERIFY_PROVIDER=openai
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Web UI Verify（阶段四）：若设置则优先使用 Anthropic Messages API 流式输出
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
